# =============================================================
# Sentinel Agent — Environment Variables
# =============================================================
# Copy this file to .env:  cp .env.example .env

# -------------------------------------------------------------
# Nosana API — For deploying to Nosana GPU network
# Get your key at https://deploy.nosana.com (Account > API Keys)
# -------------------------------------------------------------
NOSANA_API_KEY=your_nosana_api_key_here

# -------------------------------------------------------------
# LLM Configuration — OpenAI-compatible endpoint
# Nosana provides a hosted Qwen3.5-27B-AWQ-4bit endpoint
# For local dev: use any OpenAI-compatible provider
# -------------------------------------------------------------
OPENAI_API_KEY=nosana
OPENAI_API_URL=https://6vq2bcqphcansrs9b88ztxfs88oqy7etah2ugudytv2x.node.k8s.prd.nos.ci/v1
MODEL_NAME=Qwen3.5-27B-AWQ-4bit

# -------------------------------------------------------------
# Embedding Model — For RAG and semantic search
# Nosana provides a hosted Qwen3-Embedding-0.6B endpoint
# -------------------------------------------------------------
OPENAI_EMBEDDING_URL=https://4yiccatpyxx773jtewo5ccwhw1s2hezq5pehndb6fcfq.node.k8s.prd.nos.ci/v1
OPENAI_EMBEDDING_API_KEY=nosana
OPENAI_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
OPENAI_EMBEDDING_DIMENSIONS=1024

# -------------------------------------------------------------
# Agent Server
# -------------------------------------------------------------
SERVER_PORT=3000
