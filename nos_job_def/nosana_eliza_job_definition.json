{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "api"
  },
  "ops": [
    {
      "id": "sentinel-agent",
      "type": "container/run",
      "args": {
        "image": "ghcr.io/himanshu748/sentinel-nosana-agent:latest",
        "expose": 3000,
        "env": {
          "OPENAI_API_KEY": "nosana",
          "OPENAI_API_URL": "http://localhost:8000/v1",
          "MODEL_NAME": "Qwen/Qwen2.5-7B-Instruct-AWQ",
          "SERVER_PORT": "3000",
          "NODE_ENV": "production",
          "ELIZAOS_TELEMETRY_DISABLED": "true"
        },
        "resources": {
          "gpu": "1"
        }
      }
    }
  ]
}
